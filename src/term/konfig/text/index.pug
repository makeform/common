div
  style(type="text/css"): include:stylus ../index.styl
  script(type="@plotdb/block"): include:lsc index.ls
  include ../mixin.pug
  div(plug="base")
    +head
    .input-group
      input.form-control.form-control-sm(ld="input",aria-label="text")
      .input-group-append(ld="menu")
        .btn.btn-outline-secondary.border.dropdown-toggle.px-2(
        ld="dropdown",data-toggle="dropdown",style="z-index:1")
        .dropdown-menu.dropdown-menu-right.shadow-sm.z-float
          .dropdown-item(ld-each="preset")
