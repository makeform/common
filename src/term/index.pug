.ldcv.autogap
  style(type="text/css"): include:stylus index.styl
  script(type="@plotdb/block"): include:lsc index.ls
  .base.rwd.w-1024: .inner
    div(t="validation-rules")
    .mb-2
      .mb-4.d-flex.flex-column.g-2.align-items-stretch.term.rounded.shadow-sm(
      ld-each="term",style="border-left:4px solid #777")
        .d-flex.g-2.align-items-center.justify-content-between.border-bottom.pb-2.pt-2.px-3.bg-light
          .switch.switch-sm(ld="enabled",style="width:2em;flex:0 0 auto")
          .text-sm.alert.alert-success.px-2.py-0.mb-0 #[span(t="rule")] #[span(ld="idx")]
          .flex-grow-1
          .btn.btn-sm.btn-light: i.i-trashcan(ld="delete")
        .d-flex.flex-column.g-1.flex-grow-1.pb-3.px-3
          .d-flex.g-2.align-items-center.w-100
            .form-group.mb-0(style="flex:1 0 20%")
              label.text-sm.mb-0(t="ruleset")
              select.form-control.form-control-sm(ld="opset")
                option(ld-each="opset-option")
            .form-group.mb-0(style="flex:1 0 30%")
              label.text-sm.mb-0(t="rule")
              select.form-control.form-control-sm(ld="op")
                option(ld-each="op-option")
            .form-group.flex-grow-1.mb-0(style="flex:2 0 40%")
              label.text-sm.mb-0(t="errmsg")
              input.form-control.form-control-sm(ld="msg")
          .d-flex.flex-wrap.g-2.w-100
            .d-flex.flex-wrap.g-2.w-100(ld="op-cfg-root")

    .d-flex.justify-content-between.align-items-center
      .btn.btn-outline-secondary(ld="add") #[span(t="new")] #[i.i-plus]
      .btn.btn-outline-secondary(ld="close") #[span(t="ok")]

